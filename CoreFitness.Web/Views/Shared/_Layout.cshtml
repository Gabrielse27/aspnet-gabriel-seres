<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoreFitness.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CoreFitness.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav style="display: flex; justify-content: space-between; align-items: center; padding: 20px 50px; background-color: var(--bg-dark); border-bottom: 1px solid #333;">
            
            <div class="logo-container" style="display: flex; align-items: center; gap: 10px;">
                <img src="~/images/logo.svg" alt="CoreFitness Logo" style="height: 40px; width: auto;" />

                
            </div>



            <ul style="display: flex; list-style: none; gap: 30px; margin: 0; padding: 0;">
                <li><a href="/" style="color: white; text-decoration: none;">Fitness Centers</a></li>
                <li><a href="/Home/Memberships" style="color: white; text-decoration: none;">Memberships</a></li>
                <li><a href="#" style="color: white; text-decoration: none;">Training</a></li>
                <li><a href="#" style="color: white; text-decoration: none;">Customer Service</a>
                <li><a href="#" style="color: white; text-decoration: none;">Store</a></li>
            </ul>

            <div style="display: flex; align-items: center; gap: 20px;">
                <a href="/Identity/Account/Login" style="color: white; text-decoration: none;">Become Member</a>


                <a href="#" class="btn-gym">Sign In
                    <img src="~/images/arrow-right.svg" alt="" style="height: 14px; width: auto;" />
                </a>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="container">
            &copy; 2026 - CoreFitness.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
