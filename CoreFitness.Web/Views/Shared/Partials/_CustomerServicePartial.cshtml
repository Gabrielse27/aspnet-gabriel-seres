
<section class="customer-service-section">
    <h2 class="customerservice-main-title">Customer Service</h2>

    <div class="container-customerservice">



        <div class="service-left">
            <div class="cs-contact-card">



                <img src="/images/contact-women-customservice.svg" alt="Contact GymPro" class="cs-image">

                <div class="cs-contact-overlay">

                    <div class="cs-info-item">
                        <div class="icon-circle">
                            <i class="fa-solid fa-phone"></i>
                        </div>
                        <div class="info-text">
                            <span class="label">Phone Number</span>
                            <span class="value">+(46) 8 410 521 00</span>
                        </div>
                    </div>

                    <div class="cs-info-item">
                        <div class="icon-circle">
                            <i class="fa-solid fa-envelope"></i>
                        </div>
                        <div class="info-text">
                            <span class="label">Email Address</span>
                            <span class="value">info@corefitness.se</span>
                        </div>
                    </div>

                </div>
            </div>

        </div>



        <div class="cs-form-container">
            <h2 class="cs-form-title">Contact Us Today</h2>
            <p class="cs-form-text">Ready to begin your fitness journey? Contact GymPro today and let our expert trainers guide you with the right program and support.</p>

            <form class="cs-actual-form">
                <div class="cs-form-row">
                    <div class="cs-input-group">
                        <label>First Name *</label>
                        <input type="text" placeholder="Enter First Name">
                    </div>
                    <div class="cs-input-group">
                        <label>Last Name *</label>
                        <input type="text" placeholder="Enter Last Name">
                    </div>
                </div>

                <div class="cs-form-row">
                    <div class="cs-input-group">
                        <label>Email Address *</label>
                        <input type="email" placeholder="Enter Email Address">
                    </div>
                    <div class="cs-input-group">
                        <label>Phone Number</label>
                        <input type="text" placeholder="Enter Phone Number">
                    </div>
                </div>

                <div class="cs-input-group full-width">
                    <label>Message *</label>
                    <textarea placeholder="Message..."></textarea>
                </div>

                <button type="submit" class="cs-submit-btn">
                    Submit Message <i class="fa-solid fa-chevron-right"></i>
                </button>
            </form>
        </div>


    </div>
</section>
