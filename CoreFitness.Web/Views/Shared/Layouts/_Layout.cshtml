@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager




<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoreFitness.Web</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script type="importmap"></script>

    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="/CoreFitness.Web.styles.css" asp-append-version="true" />
</head>





<body class="@ViewData["BodyClass"]">
    <header>

       
        <nav class ="main-navbar" style="display: flex; justify-content: space-between; align-items: center;
 padding: 20px 50px; background-color: var(--bg-dark); border-bottom: 1px solid #333; ">
            

            <div class="logo-container" style="display: flex; align-items: center; gap: 10px;">
                <img src="~/images/logo.svg" alt="CoreFitness Logo" style="height: 40px; width: auto;" />


            </div>


            <ul style="display: flex; list-style: none; gap: 30px; margin: 0; padding: 0;">
                <li><a class="nav-link" asp-controller="Home" asp-action="Index" >Fitness Centers</a></li>
                <li><a class="nav-link" asp-controller="Home" asp-action="Memberships" >Memberships</a></li>


              <li class="nav-item dropdown">
                  <a class="nav-link dropdown-toggle" href="#">
                        Training<i class="fa-solid fa-chevron-down"></i>
                  </a>
                  <ul class="custom-dropdown-menu">

                        <ul class="custom-dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="PersonalTraining">Personal Training</a></li>
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="GroupTraining">Group Training</a></li>
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="Padel">Padel</a></li>

                       </ul>
                  </ul>

              </li> 


                <li><a class="nav-link"asp-controller="Home" asp-action="CustomerService">Customer Service</a></li>
            
              
                    <li><a class="nav-link"asp-controller="Home" asp-action="Store" >Store</a></li>
                </ul>

                <div style="display: flex; align-items: center; gap: 20px;">
                    <a href="/Identity/Account/Register" style="color: white; text-decoration: none,;">Become Member</a>


                    
                </div>


            <div class="ms-auto">
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-controller="Home" asp-action="Account" class="btn-gym">My Account <i class="fa-solid fa-chevron-right"></i></a>
                }
                else
                {
                    <a href="/Identity/Account/Login" class="btn-gym">Sign In <i class="fa-solid fa-chevron-right" style="transform: translateY(1.2px)"></i></a>
                }
            </div>



            </nav>
        </header>
        <main role="main">
            @RenderBody()
        </main>





  

    <section class="footer-sectionen">
        <footer class="main-footer">
            <div class="footer-container">
                <div class="footer-top">
                    <div class="footer-logo">
                        <img src="~/images/logotype-core-footer.svg" alt="" style=width: 180px; height: auto; display: block; />
                        
                    </div>
                    <div class="footer-motto">
                        <h3>Empowering Your Fitness Journey with Expert<br> Training and Lasting Results</h3>
                    </div>
                </div>

                <hr class="footer-divider">

                <div class="footer-content">
                    <div class="footer-column location">
                       
                        <h4>Our Location</h4>
                        <p>Our supportive and knowledgeable trainers work
                            <br /> with members to provide encouragement.</p>
                        <div class="address-info">
                            <img src="/images/footer-location-map.svg" alt="Map">
                            <span>2nd Floor, Wellness Center, Drottninggatan 118, Stockholm</span>
                        </div>
                    </div>

                    <div class="footer-column hours">
                        <div class="hour-group">
                            <h4>Working Hours</h4>
                            <p>Mon – Fri: 06:00 – 18:00</p>
                            <p>Saturday: 10:00 – 18:00</p>
                        </div>
                        <div class="hour-group">
                            <h4>Opening Hours</h4>
                            <p>Mon – Sun: 04:00 – 23:00</p>
                        </div>
                    </div>
                </div>

                <hr class="footer-divider-down">

                <div class="footer-bottom">
                    <p>&copy; 2026 Core Fitness Group. All Rights Reserved.</p>
                </div>
            </div>
        </footer>
    </section>











        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)

        






    </body>

</html>