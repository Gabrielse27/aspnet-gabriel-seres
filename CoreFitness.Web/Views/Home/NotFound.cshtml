
@{
    Layout = "_Layout";// Använder din vanliga navbar/footer
    ViewData["Title"] = "Page Not Found";
   
}


<section class="error-section" style="padding: 80px 0; text-align: center; min-height: 60vh; display: flex; align-items: center; justify-content: center;">
    <div class="container">
        <div class="error-visual" style="display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 20px;">
            <span style="font-size: 150px; font-weight: 900; color: #0b0e14;">4</span>
            <img src="~/images/not-found-section.svg" alt="404 Illustration" style="height: 200px;" />
            <span style="font-size: 150px; font-weight: 900; color: #0b0e14;">4</span>
        </div>

        <h1 style="font-size: 40px; font-weight: 800; color: #0b0e14; margin-bottom: 10px;">Oops! page not found</h1>
        <p style="color: #666; margin-bottom: 30px;">The page you are looking for does not exists.</p>

        <a href="/" style="background-color: #D2EF39; color: #000; padding: 15px 35px; border-radius: 50px; text-decoration: none; font-weight: bold; display: inline-flex; align-items: center; gap: 10px;">
            Back to Homepage <i class="fa-solid fa-chevron-right"></i>
        </a>
    </div>
</section>



