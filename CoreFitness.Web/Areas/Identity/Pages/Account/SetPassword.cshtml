@page
@model CoreFitness.Web.Areas.Identity.Pages.Account.SetPasswordModel
@{
    ViewData["Title"] = "Set Your Password";
    ViewData["HideFooter"] = true;
}



<section class="setpassword-section">
    <div class="setpassword-card">
        <h1>Set Your Password</h1>
        <p class="setpassword-text" style="border-bottom: 1px solid #eee; padding-bottom: 20px; margin-bottom: 20px; text-align: left">
            Set a strong password to protect your account. For security reasons, your password must be at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.
        </p>

        <form method="post">
            <div class="form-group" style="display: flex; flex-direction: column; align-items: flex-start; margin-bottom: 15px;">
                <label asp-for="Input.Email" style="font-weight: bold; font-size: 12px; margin-bottom: 5px;">Email Address</label>
                <input asp-for="Input.Email" class="form-control" placeholder="username@@domain.com" style="width: 100%; background: #f8f8f8; border: 1px solid #eee; padding: 12px; border-radius: 8px;" />
            </div>

            <div class="form-group" style="display: flex; flex-direction: column; align-items: flex-start; margin-bottom: 25px;">
                <label asp-for="Input.Password" style="font-weight: bold; font-size: 12px; margin-bottom: 5px;">Password</label>
                <input asp-for="Input.Password" class="form-control" placeholder="Enter Password" style="width: 100%; background: #f8f8f8; border: 1px solid #eee; padding: 12px; border-radius: 8px;" />
            </div>

            <button type="submit" class="btn-continue" style="width: 80%; background-color: #D2EF39; border: none; padding: 12px; border-radius: 50px; font-weight: 600; cursor: pointer; ">
                Continue <i class="fa-solid fa-chevron-right" style="margin-left: 10px;"></i>
            </button>

            <div style="margin-top: 20px; display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 12px; color: #666;">
                <input type="checkbox" asp-for="Input.AcceptTerms" />
                <label asp-for="Input.AcceptTerms">Accept user terms and conditions</label>
            </div>
        </form>
    </div>
</section>


<style>
    footer {
        display: none !important;
    }
</style>