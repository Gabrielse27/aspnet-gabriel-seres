@page
@model LoginModel
@using CoreFitness.Domain.Entities
@using CoreFitness.Domain.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "Log in";

    ViewData["HideFooter"] = true;
}

<head>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
</head>


<section class="signin-section">
    <div class="signin-card">
        <h1>Welcome Back!</h1>
        <p class="signin-text" style="text-align: left;">Log in to continue your fitness journey with full access to your customized a god program,training history, and progress tracking.  Stay consistent,  monitor 
                your development, and keep moving forward with the structure and support built into your account.</p>

        <div class="social-login">


            <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="form-horizontal">
    <div>
        <p>
            
                        <button type="submit" name="provider" value="Google" class="gsi-material-button mt-1.5">
                            <div class="gsi-material-button-state"></div>
                            <div class="gsi-material-button-content-wrapper">
                                <div class="gsi-material-button-icon">
                                    <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" xmlns:xlink="http://www.w3.org/1999/xlink" style="display: block;">
                                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path>
                                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path>
                                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path>
                                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path>
                                        <path fill="none" d="M0 0h48v48H0z"></path>
                                    </svg>
                                </div>
                                <span class="gsi-material-button-contents">SignIn with Google</span>
                                <span style="display: none;">Continue with Google</span>
                            </div>
                        </button>

        </p>
    </div>
</form>


            <a href="#" class="social-btn"><img src="~/images/facebook-sign.in-welcome.svg" alt="Facebook" /></a>
            <a href="#" class="social-btn"><img src="~/images/github-sign.in-welcome.svg" alt="GitHub" /></a>
        </div>

        <div class="divider">
            <span>OR CONTINUE WITH</span>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-group">
                <label asp-for="Input.Email">Email Address *</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Enter Email Address" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div class="label-row" style="display: flex; justify-content: space-between; width: 100%; text-align: center;">
                    <label asp-for="Input.Password">Password</label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="forgot-password" style="color: #D2EF39; font-size: 12px; text-decoration: none;">Forgot your password?</a>
                </div>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Enter Password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <button id="login-submit" type="submit" class="btn-continue">Continue 
                <i class="fa-solid fa-chevron-right"></i></button>

            <div class="terms-check" style="margin-top: 20px; font-size: 12px; color: #666;">
                <input asp-for="Input.RememberMe" />
                <label asp-for="Input.RememberMe">Accept user terms and conditions</label>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    footer {
        display: none !important;
    }
</style>